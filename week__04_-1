import random

def playAddOnce():
    # 10~99 사이의 두 자리 수 생성
    num1 = random.randint(10, 99)
    num2 = random.randint(10, 99)
    
    answer = int(input(f"{num1} + {num2} = "))
    
    if answer == (num1 + num2):
        print("정답임")
    else:
        print(f"틀렸음. 정답은 {num1 + num2}")

playAddOnce()
