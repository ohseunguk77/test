#include <stdio.h>
#include <stdlib.h>
#include <time.h>

// 1. 함수 정의: 임의의 0과 1 채우기
void randomMap(int map[5][5]) {
    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            map[i][j] = rand() % 2;
        }
    }
}

// 2. 함수 정의: 화면에 출력하기
void printMap(int map[5][5]) {
    printf("=== 5x5 Checker Board ===\n");
    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            printf("%d ", map[i][j]);
        }
        printf("\n");
    }
    printf("=========================\n");
}

// 3. 함수 정의: 가로, 세로, 대각선 체크하기
void checkMap(int map[5][5]) {
    int i, j, target, complete;

    for (i = 0; i < 5; i++) {
        target = map[i][0];
        complete = 1;
        for (j = 1; j < 5; j++) {
            if (map[i][j] != target) { complete = 0; break; }
        }
        if (complete) printf("가로 %d행이 모두 %d임.\n", i + 1, target);
    }

    for (j = 0; j < 5; j++) {
        target = map[0][j];
        complete = 1;
        for (i = 1; i < 5; i++) {
            if (map[i][j] != target) { complete = 0; break; }
        }
        if (complete) printf("세로 %d열이 모두 %d임.\n", j + 1, target);
    }

    target = map[0][0];
    complete = 1;
    for (i = 1; i < 5; i++) {
        if (map[i][i] != target) { complete = 0; break; }
    }
    if (complete) printf("주 대각선이 모두 %d임.\n", target);

    target = map[0][4];
    complete = 1;
    for (i = 1; i < 5; i++) {
        if (map[i][4 - i] != target) { complete = 0; break; }
    }
    if (complete) printf("부 대각선이 모두 %d임.\n", target);
}

// 실질적으로 프로그램을 실행하는 부분
int main() {
    int board[5][5];
    srand(time(NULL)); // 실행할 때마다 랜덤값 변경함

    randomMap(board);  // 배열 채움
    printMap(board);   // 화면 출력함
    checkMap(board);   // 결과 확인함

    return 0;
}
