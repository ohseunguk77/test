#include <iostream>
using namespace std;

int main() {
    // (1)
    for (int i = 1; i <= 5; i++) {
        for (int j = 1; j <= i; j++) cout << j << " ";
        cout << endl;
    }
    cout << endl;

    // (2)
    for (int i = 5; i >= 1; i--) {
        for (int j = 5; j >= 5 - i + 1; j--) cout << j << " ";
        cout << endl;
    }
    cout << endl;

    // (3)
    for (int i = 1; i <= 5; i++) {
        for (int j = 0; j < 5 - i; j++) cout << "  ";
        for (int j = i; j >= 1; j--) cout << j << " ";
        cout << endl;
    }
    cout << endl;

    // (4)
    for (int i = 1; i <= 5; i++) {
        for (int j = 0; j < 5 - i; j++) cout << "  ";
        for (int j = i; j >= 1; j--) cout << j << " ";
        for (int j = 2; j <= i; j++) cout << j << " ";
        cout << endl;
    }
    return 0;
}
